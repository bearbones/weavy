@@ -0,0 +1,45 @@
+import { db } from "../db/connection";
+import { hashPassword, verifyPassword } from "../utils/crypto";
+import type { User, UserSession, CreateUserRequest } from "../types/user";
+
+export async function createUser(req: CreateUserRequest): Promise<User> {
+  const existing = await db.users.findByEmail(req.email);
+  if (existing) {
+    throw new Error("User with this email already exists");
+  }
+
+  const user = await db.users.insert({
+    email: req.email,
+    displayName: req.displayName,
+    role: req.role,
+    createdAt: new Date(),
+    lastLoginAt: null,
+  });
+
+  return user;
+}
+
+export async function login(
+  email: string,
+  password: string,
+): Promise<UserSession> {
+  const user = await db.users.findByEmail(email);
+  if (!user) {
+    throw new Error("Invalid credentials");
+  }
+
+  const valid = await verifyPassword(password, user.passwordHash);
+  if (!valid) {
+    throw new Error("Invalid credentials");
+  }
+
+  await db.users.update(user.id, { lastLoginAt: new Date() });
+
+  const session = await db.sessions.create({
+    userId: user.id,
+    token: crypto.randomUUID(),
+    expiresAt: new Date(Date.now() + 24 * 60 * 60 * 1000),
+  });
+
+  return session;
+}
